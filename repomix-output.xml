            CREATE TABLE IF NOT EXISTS Bookings (
                booking_id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                event_id INT NOT NULL,
                ticket_type_id INT,
                unique_code VARCHAR(255) UNIQUE NOT NULL,
